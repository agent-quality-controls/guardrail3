{
  "name": "g3ts-astro-llms",
  "version": "0.1.1",
  "description": "Narrow Astro integration that generates llms.txt during build.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/websmasher/guardrail3.git",
    "directory": "packages/ts/astro/integrations/g3ts-astro-llms"
  },
  "homepage": "https://github.com/websmasher/guardrail3/tree/main/packages/ts/astro/integrations/g3ts-astro-llms",
  "bugs": {
    "url": "https://github.com/websmasher/guardrail3/issues"
  },
  "keywords": [
    "astro",
    "llms.txt",
    "guardrails",
    "g3ts"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepack": "npm run clean && npm run build",
    "prepublishOnly": "npm test",
    "pretest": "npm run build",
    "test": "tsx --test tests/*.test.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "astro": "^6.0.0"
  },
  "dependencies": {
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "astro": "^6.1.9",
    "tsx": "^4.20.6",
    "typescript": "5.9.3"
  }
}
