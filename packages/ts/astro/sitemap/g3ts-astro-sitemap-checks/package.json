{
  "name": "g3ts-astro-sitemap-checks",
  "version": "0.1.2",
  "description": "Post-build sitemap XML checks for Astro output.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/websmasher/guardrail3.git",
    "directory": "packages/ts/astro/sitemap/g3ts-astro-sitemap-checks"
  },
  "homepage": "https://github.com/websmasher/guardrail3/tree/main/packages/ts/astro/sitemap/g3ts-astro-sitemap-checks",
  "bugs": {
    "url": "https://github.com/websmasher/guardrail3/issues"
  },
  "keywords": [
    "astro",
    "sitemap",
    "xml",
    "guardrails",
    "g3ts"
  ],
  "license": "MIT",
  "type": "module",
  "bin": {
    "g3ts-astro-sitemap-checks": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepack": "npm run clean && npm run build",
    "prepublishOnly": "npm test",
    "pretest": "npm run build",
    "test": "tsx --test tests/*.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "fast-xml-parser": "^5.2.5"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "tsx": "^4.20.6",
    "typescript": "5.9.3"
  }
}
