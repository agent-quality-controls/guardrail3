#!/usr/bin/env bash
set -euo pipefail

usage() {
    echo "usage: scripts/g3ts/verify --mode pre-commit|workspace --scope <path>" >&2
}

MODE=""
SCOPE_ARG=""

while [ "$#" -gt 0 ]; do
    case "$1" in
        --mode)
            [ "$#" -ge 2 ] || { usage; exit 2; }
            [ -z "$MODE" ] || { usage; exit 2; }
            MODE="$2"
            shift 2
            ;;
        --scope)
            [ "$#" -ge 2 ] || { usage; exit 2; }
            [ -z "$SCOPE_ARG" ] || { usage; exit 2; }
            SCOPE_ARG="$2"
            shift 2
            ;;
        --*)
            usage
            exit 2
            ;;
        *)
            usage
            exit 2
            ;;
    esac
done

[ -n "$MODE" ] || { usage; exit 2; }
[ -n "$SCOPE_ARG" ] || { usage; exit 2; }

case "$MODE" in
    pre-commit|workspace) ;;
    *) usage; exit 2 ;;
esac

REPO_ROOT="$(git rev-parse --show-toplevel)"
REPO_ROOT="$(cd "$REPO_ROOT" && pwd -P)"

case "$SCOPE_ARG" in
    /*) SCOPE="$SCOPE_ARG" ;;
    *) SCOPE="$REPO_ROOT/$SCOPE_ARG" ;;
esac

SCOPE="$(cd "$SCOPE" && pwd -P)"

if [ "$MODE" = "pre-commit" ] && [ "$SCOPE" = "$REPO_ROOT" ]; then
    echo "G3TS pre-commit mode requires a concrete app/package scope, not repo root." >&2
    exit 2
fi

staged_ts_relevant_paths() {
    git diff --cached --name-only --diff-filter=ACM | grep -E '(^|/)(package\.json|pnpm-lock\.yaml|package-lock\.json|yarn\.lock|bun\.lockb|bun\.lock|npm-shrinkwrap\.json|pnpm-workspace\.yaml|tsconfig[^/]*\.json|eslint\.config\.[^/]+|\.eslintrc(\.[^/]+)?|prettier\.config\.[^/]+|\.prettierrc(\.[^/]+)?|cspell\.(json|ya?ml)|cspell\.config\.(json|js|mjs|cjs|ts)|\.cspell\.(json|ya?ml)|stylelint\.config\.[^/]+|\.stylelintrc(\.[^/]+)?|syncpack\.config\.[^/]+|\.syncpackrc(\.[^/]+)?|type-coverage\.(json|config\.[^/]+)|guardrail3-ts\.toml)$|\.(ts|tsx|mts|cts|mjs|cjs|js|jsx|css)$' || true
}

package_has_script() {
    local scope="$1"
    local script="$1"
    script="$2"
    [ -f "$scope/package.json" ] && grep -Eq "\"$script\"[[:space:]]*:" "$scope/package.json"
}

run_typecheck() {
    local scope="$1"
    if package_has_script "$scope" typecheck; then
        (cd "$scope" && pnpm run typecheck)
    elif [ -f "$scope/tsconfig.json" ]; then
        (cd "$scope" && pnpm exec tsc -p "$scope/tsconfig.json" --noEmit)
    else
        (cd "$scope" && pnpm exec tsc --noEmit)
    fi
}

run_lint() {
    local scope="$1"
    if package_has_script "$scope" lint; then
        (cd "$scope" && pnpm run lint)
    else
        (cd "$scope" && pnpm exec eslint --max-warnings 0 "$scope")
    fi
}

run_format_check() {
    local scope="$1"
    if package_has_script "$scope" format:check; then
        (cd "$scope" && pnpm run format:check)
    elif package_has_script "$scope" check:format; then
        (cd "$scope" && pnpm run check:format)
    else
        (cd "$scope" && pnpm exec prettier --check "$scope")
    fi
}

run_spelling_check() {
    local scope="$1"
    if package_has_script "$scope" spellcheck; then
        (cd "$scope" && pnpm run spellcheck)
    elif package_has_script "$scope" spelling; then
        (cd "$scope" && pnpm run spelling)
    else
        (cd "$scope" && pnpm exec cspell --no-progress --no-summary "$scope")
    fi
}

style_family_enabled() {
    local scope="$1"
    [ -f "$scope/stylelint.config.js" ] || [ -f "$scope/stylelint.config.mjs" ] || [ -f "$scope/stylelint.config.cjs" ] ||
        [ -f "$scope/stylelint.config.ts" ] || [ -f "$scope/.stylelintrc" ] || [ -f "$scope/.stylelintrc.json" ] ||
        [ -f "$scope/.stylelintrc.yaml" ] || [ -f "$scope/.stylelintrc.yml" ] || [ -f "$scope/.stylelintrc.js" ] ||
        [ -f "$scope/.stylelintrc.cjs" ] || [ -f "$scope/.stylelintrc.mjs" ]
}

package_family_enabled() {
    local scope="$1"
    [ -f "$scope/package.json" ]
}

typecov_family_enabled() {
    local scope="$1"
    package_has_script "$scope" typecov ||
        { [ -f "$scope/package.json" ] && grep -Eq '"type-coverage"[[:space:]]*:' "$scope/package.json"; } ||
        [ -f "$scope/type-coverage.json" ] ||
        [ -f "$scope/type-coverage.config.js" ] ||
        [ -f "$scope/type-coverage.config.mjs" ] ||
        [ -f "$scope/type-coverage.config.cjs" ] ||
        [ -f "$scope/type-coverage.config.ts" ]
}

run_stylelint_check() {
    local scope="$1"
    if package_has_script "$scope" stylelint; then
        (cd "$scope" && pnpm run stylelint)
    else
        (cd "$scope" && pnpm exec stylelint --max-warnings 0 "$scope/**/*.css")
    fi
}

run_package_policy_check() {
    local scope="$1"
    if package_has_script "$scope" package:policy; then
        (cd "$scope" && pnpm run package:policy)
    elif package_has_script "$scope" syncpack; then
        (cd "$scope" && pnpm run syncpack)
    else
        (cd "$scope" && pnpm exec syncpack lint)
    fi
}

run_typecov_check() {
    local scope="$1"
    if package_has_script "$scope" typecov; then
        (cd "$scope" && pnpm run typecov)
    else
        (cd "$scope" && pnpm exec type-coverage --at-least 100)
    fi
}

discover_scopes() {
    local discovered=0
    if [ -f "$SCOPE/package.json" ]; then
        printf '%s\n' "$SCOPE"
        discovered=1
    fi
    for root in "$SCOPE/apps" "$SCOPE/packages"; do
        [ -d "$root" ] || continue
        while IFS= read -r package_file; do
            printf '%s\n' "${package_file%/package.json}"
            discovered=1
        done < <(find "$root" -path '*/node_modules/*' -prune -o -name package.json -type f -print 2>/dev/null | sort)
    done
    [ "$discovered" -eq 1 ] || {
        echo "No TypeScript verifier scope found under $SCOPE" >&2
        return 1
    }
}

run_verifiers_for_scope() {
    local scope="$1"
    if [ "$scope" = "$SCOPE" ]; then
        g3ts validate --path "$SCOPE"
    else
        g3ts validate --path "$scope"
    fi

    run_typecheck "$scope"
    run_lint "$scope"
    run_format_check "$scope"
    run_spelling_check "$scope"

    if style_family_enabled "$scope"; then
        run_stylelint_check "$scope"
    fi
    if package_family_enabled "$scope"; then
        run_package_policy_check "$scope"
    fi
    if typecov_family_enabled "$scope"; then
        run_typecov_check "$scope"
    fi
}

if [ "$MODE" = "pre-commit" ]; then
    TS_RELEVANT_STAGED_PATHS="$(staged_ts_relevant_paths)"
    [ -n "$TS_RELEVANT_STAGED_PATHS" ] || exit 0
fi

if ! VERIFIER_SCOPES="$(discover_scopes)"; then
    exit 1
fi

while IFS= read -r verifier_scope; do
    [ -n "$verifier_scope" ] || continue
    run_verifiers_for_scope "$verifier_scope"
done <<< "$VERIFIER_SCOPES"
