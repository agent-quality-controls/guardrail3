#!/usr/bin/env bash
set -euo pipefail

usage() {
  printf '%s\n' "$1" >&2
  printf '%s\n' 'usage: scripts/g3rs/verify --mode pre-commit|workspace --scope <path>' >&2
  exit 2
}

MODE=""
SCOPE_ARG=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --mode)
      [[ $# -ge 2 ]] || usage 'missing value for --mode'
      MODE="$2"
      shift 2
      ;;
    --scope)
      [[ $# -ge 2 ]] || usage 'missing value for --scope'
      SCOPE_ARG="$2"
      shift 2
      ;;
    --*)
      usage "unknown flag: $1"
      ;;
    *)
      usage "unexpected argument: $1"
      ;;
  esac
done

[[ -n "$MODE" ]] || usage 'missing --mode'
[[ -n "$SCOPE_ARG" ]] || usage 'missing --scope'

case "$MODE" in
  pre-commit | workspace)
    ;;
  *)
    usage "unknown --mode: $MODE"
    ;;
esac

REPO_ROOT="$(git rev-parse --show-toplevel)"
export CARGO_TARGET_DIR="$REPO_ROOT/.cargo-target"

if [[ "$SCOPE_ARG" = /* ]]; then
  SCOPE="$SCOPE_ARG"
else
  SCOPE="$PWD/$SCOPE_ARG"
fi
SCOPE="$(cd "$SCOPE" && pwd -P)"

is_rust_relevant_path() {
  case "$1" in
    *.rs | Cargo.toml | Cargo.lock | */Cargo.toml | */Cargo.lock)
      return 0
      ;;
    rust-toolchain | rust-toolchain.toml | rustfmt.toml | clippy.toml | deny.toml | guardrail3-rs.toml)
      return 0
      ;;
    */rust-toolchain | */rust-toolchain.toml | */rustfmt.toml | */clippy.toml | */deny.toml | */guardrail3-rs.toml)
      return 0
      ;;
    .cargo/config | .cargo/config.toml | */.cargo/config | */.cargo/config.toml)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

run_workspace_verifier() {
  g3rs validate --path "$SCOPE"

  (
    cd "$SCOPE"
    cargo metadata --locked
    cargo fmt --all -- --check
    cargo clippy --workspace --all-targets --all-features -- -D warnings
    cargo deny check
    cargo machete
    cargo test --workspace
    cargo mutants --check --in-place
  )
}

run_duplication_verifier() {
  (
    cd "$SCOPE"
    cargo dupes check --max-exact 85 --max-exact-percent 10 --exclude-tests
  )
}

case "$MODE" in
  pre-commit)
    rust_relevant=0
    rust_source=0
    while IFS= read -r staged_path; do
      [[ -n "$staged_path" ]] || continue
      if is_rust_relevant_path "$staged_path"; then
        rust_relevant=1
      fi
      case "$staged_path" in
        *.rs)
          rust_source=1
          ;;
      esac
    done < <(git diff --cached --name-only --diff-filter=ACM)

    [[ "$rust_relevant" -eq 1 ]] || exit 0

    run_workspace_verifier

    if [[ "$rust_source" -eq 1 ]]; then
      run_duplication_verifier
    fi
    ;;
  workspace)
    run_workspace_verifier
    run_duplication_verifier
    ;;
esac
