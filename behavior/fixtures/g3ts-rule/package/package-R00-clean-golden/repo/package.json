{
  "private": true,
  "packageManager": "pnpm@10.32.0",
  "engines": {
    "node": ">=24",
    "pnpm": "10"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prepare": "echo prepare",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "syncpack:lint": "syncpack lint",
    "validate": "pnpm lint && pnpm typecheck && pnpm syncpack:lint"
  },
  "devDependencies": {
    "syncpack": "latest",
    "typescript": "5.9.3"
  },
  "pnpm": {
    "overrides": {
      "@eslint/js": "^9.0.0",
      "zod": "^4.0.0"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
