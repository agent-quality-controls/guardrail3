#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
export CARGO_TARGET_DIR="$REPO_ROOT/.cargo-target"

# Collect staged files once.
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
    echo "No staged files. Skipping pre-commit checks."
    exit 0
fi

# --- Merge-conflict marker scan ---
echo "Checking for merge conflict markers..."
CONFLICT_FILES=""
while IFS= read -r file; do
    [ -n "$file" ] || continue
    [ -f "$file" ] || continue
    if grep -qE '^(<{7} |={7}$|>{7} )' "$file" 2>/dev/null; then
        CONFLICT_FILES="$CONFLICT_FILES $file"
    fi
done <<< "$STAGED_FILES"
if [ -n "$CONFLICT_FILES" ]; then
    echo "Merge conflict markers found in:$CONFLICT_FILES"
    exit 1
fi

# --- Secret scanning ---
echo "Scanning for secrets..."
if ! command -v gitleaks &> /dev/null; then
    echo "ERROR: gitleaks not installed. Install: brew install gitleaks"
    exit 1
fi
if ! gitleaks protect --staged --no-banner; then
    echo "Secret detected in staged files. Remove it before committing."
    exit 1
fi

# --- File size cap ---
echo "Checking file sizes..."
MAX_FILE_SIZE=1048576  # 1MB
while IFS= read -r file; do
    [ -n "$file" ] || continue
    if git cat-file -e ":$file" 2>/dev/null; then
        file_size=$(git cat-file -s ":$file")
        if [ "$file_size" -gt "$MAX_FILE_SIZE" ]; then
            echo "File $file is too large (${file_size} bytes, max ${MAX_FILE_SIZE}). Use Git LFS for large files."
            exit 1
        fi
    fi
done <<< "$STAGED_FILES"

# --- Migration consistency ---
echo "Checking migration consistency..."
MIGRATION_FILES=$(echo "$STAGED_FILES" | grep -E 'drizzle/' || true)
if [ -n "$MIGRATION_FILES" ]; then
    MODIFIED_MIGRATIONS=$(git diff --cached --name-only --diff-filter=M | grep -E 'drizzle/' || true)
    if [ -n "$MODIFIED_MIGRATIONS" ]; then
        echo "Error: Existing migration files should not be modified:"
        echo "$MODIFIED_MIGRATIONS"
        echo "Create a new migration instead."
        exit 1
    fi
fi

SCHEMA_CHANGED=$(echo "$STAGED_FILES" | grep -E 'db/schema/.*\.ts$' || true)
NEW_MIGRATIONS=$(echo "$STAGED_FILES" | grep -E 'drizzle/.*\.sql$' || true)
if [ -n "$SCHEMA_CHANGED" ] && [ -z "$NEW_MIGRATIONS" ]; then
    echo "Error: DB schema changed but no migration file added."
    echo "Run 'pnpm exec drizzle-kit generate' and stage the migration."
    exit 1
fi

# --- Lockfile integrity ---
STAGED_PACKAGE_JSON=$(echo "$STAGED_FILES" | grep -E '(^|/)package\.json$' || true)
if [ -n "$STAGED_PACKAGE_JSON" ]; then
    echo "Checking lockfile integrity..."
    while IFS= read -r package_json; do
        [ -n "$package_json" ] || continue
        package_dir=$(dirname "$package_json")

        if [ -f "$package_dir/pnpm-lock.yaml" ]; then
            if ! (cd "$package_dir" && pnpm install --frozen-lockfile >/dev/null); then
                echo "$package_dir/pnpm-lock.yaml is out of sync with package.json. Run 'cd \"$package_dir\" && pnpm install'."
                exit 1
            fi
            continue
        fi

        if [ -f "$package_dir/package-lock.json" ]; then
            if ! (cd "$package_dir" && npm install --package-lock-only --ignore-scripts --dry-run >/dev/null); then
                echo "$package_dir/package-lock.json is out of sync with package.json. Run 'cd \"$package_dir\" && npm install --package-lock-only'."
                exit 1
            fi
            continue
        fi

        if [ "$package_dir" = "." ] && [ -f "$REPO_ROOT/pnpm-workspace.yaml" ]; then
            if ! (cd "$REPO_ROOT" && pnpm install --frozen-lockfile >/dev/null); then
                echo "Root pnpm-lock.yaml is out of sync with package.json. Run 'pnpm install' first."
                exit 1
            fi
            continue
        fi

        echo "No supported lockfile found for $package_json. Add package-lock.json or pnpm-lock.yaml."
        exit 1
    done <<< "$STAGED_PACKAGE_JSON"
fi

# --- Repo-level invariants ---
g3rs validate-repo
g3ts validate-repo

# --- Owning-unit discovery helpers ---

# Walk upward from a starting directory, looking for the nearest ancestor
# containing both marker files. Echoes the absolute path, returns 1 if none
# is found before the repo root.
find_owning_unit() {
    local start_dir="$1"
    local marker_a="$2"
    local marker_b="$3"
    local marker_a_check="$4"  # "any" or "workspace"

    local dir="$start_dir"
    while :; do
        if [ -f "$dir/$marker_a" ] && [ -f "$dir/$marker_b" ]; then
            if [ "$marker_a_check" = "workspace" ]; then
                if grep -qE '^[[:space:]]*\[workspace\]' "$dir/$marker_a" 2>/dev/null; then
                    echo "$dir"
                    return 0
                fi
            else
                echo "$dir"
                return 0
            fi
        fi
        if [ "$dir" = "$REPO_ROOT" ] || [ "$dir" = "/" ] || [ -z "$dir" ]; then
            return 1
        fi
        dir=$(dirname "$dir")
    done
}

# Resolve the directory of a staged file, relative to repo root, as an
# absolute path under $REPO_ROOT.
staged_file_dir() {
    local rel="$1"
    local d
    d=$(dirname "$rel")
    if [ "$d" = "." ] || [ -z "$d" ]; then
        echo "$REPO_ROOT"
    else
        echo "$REPO_ROOT/$d"
    fi
}

# --- Rust discovery loop ---
RUST_RELEVANT_PATTERN='(\.rs$|(^|/)Cargo\.toml$|(^|/)Cargo\.lock$|(^|/)rust-toolchain$|(^|/)rust-toolchain\.toml$|(^|/)rustfmt\.toml$|(^|/)\.rustfmt\.toml$|(^|/)clippy\.toml$|(^|/)\.clippy\.toml$|(^|/)deny\.toml$|(^|/)\.deny\.toml$|(^|/)guardrail3-rs\.toml$|(^|/)\.cargo/config$|(^|/)\.cargo/config\.toml$|(^|/)README\.md$|(^|/)Readme\.md$|(^|/)readme\.md$|(^|/)cliff\.toml$|(^|/)release-plz\.toml$)'
RUST_RELEVANT_FILES=$(echo "$STAGED_FILES" | grep -E "$RUST_RELEVANT_PATTERN" || true)

RUST_OWNING_UNITS=""
if [ -n "$RUST_RELEVANT_FILES" ]; then
    while IFS= read -r file; do
        [ -n "$file" ] || continue
        start_dir=$(staged_file_dir "$file")
        if unit=$(find_owning_unit "$start_dir" "Cargo.toml" "guardrail3-rs.toml" "workspace"); then
            RUST_OWNING_UNITS="${RUST_OWNING_UNITS}${unit}"$'\n'
        fi
    done <<< "$RUST_RELEVANT_FILES"
fi

RUST_UNIQUE_UNITS=$(printf '%s' "$RUST_OWNING_UNITS" | awk 'NF' | sort -u)

if [ -n "$RUST_UNIQUE_UNITS" ]; then
    echo "Running Rust validate per owning unit..."
    while IFS= read -r unit; do
        [ -n "$unit" ] || continue
        g3rs validate --path "$unit" --staged
    done <<< "$RUST_UNIQUE_UNITS"
fi

# --- TS discovery loop ---
TS_RELEVANT_PATTERN='(\.(ts|tsx|mts|cts|mjs|cjs|js|jsx|css)$|(^|/)package\.json$|(^|/)pnpm-lock\.yaml$|(^|/)package-lock\.json$|(^|/)yarn\.lock$|(^|/)bun\.lockb$|(^|/)bun\.lock$|(^|/)npm-shrinkwrap\.json$|(^|/)tsconfig[^/]*\.json$|(^|/)eslint\.config\.[^/]+$|(^|/)\.eslintrc(\.[^/]+)?$|(^|/)\.prettierrc(\.[^/]+)?$|(^|/)prettier\.config\.[^/]+$|(^|/)\.cspell\.json$|(^|/)cspell\.config\.[^/]+$|(^|/)cspell\.json$|(^|/)stylelint\.config\.[^/]+$|(^|/)\.stylelintrc(\.[^/]+)?$|(^|/)\.syncpackrc(\.[^/]+)?$|(^|/)syncpack\.config\.[^/]+$|(^|/)\.type-coverage\.[^/]+$|(^|/)type-coverage\.[^/]+$|(^|/)guardrail3-ts\.toml$)'
TS_RELEVANT_FILES=$(echo "$STAGED_FILES" | grep -E "$TS_RELEVANT_PATTERN" || true)

TS_OWNING_UNITS=""
if [ -n "$TS_RELEVANT_FILES" ]; then
    while IFS= read -r file; do
        [ -n "$file" ] || continue
        start_dir=$(staged_file_dir "$file")
        if unit=$(find_owning_unit "$start_dir" "package.json" "guardrail3-ts.toml" "any"); then
            TS_OWNING_UNITS="${TS_OWNING_UNITS}${unit}"$'\n'
        fi
    done <<< "$TS_RELEVANT_FILES"
fi

TS_UNIQUE_UNITS=$(printf '%s' "$TS_OWNING_UNITS" | awk 'NF' | sort -u)

if [ -n "$TS_UNIQUE_UNITS" ]; then
    echo "Running TS validate per owning unit..."
    while IFS= read -r unit; do
        [ -n "$unit" ] || continue
        g3ts validate --path "$unit" --staged
    done <<< "$TS_UNIQUE_UNITS"
fi

echo "All pre-commit checks passed."
